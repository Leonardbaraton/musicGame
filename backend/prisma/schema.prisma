generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Room {
  id        String   @id @default(uuid())
  code      String   @unique
  createdAt DateTime @default(now())
  players   Player[]
}

model Player {
  id        String   @id @default(uuid())
  name      String
  photoUrl  String?
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id])
  joinedAt  DateTime @default(now())
}
